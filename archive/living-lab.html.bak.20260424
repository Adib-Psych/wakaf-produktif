<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Living Lab — Wakaf Produktif Kebun Kopi Ngantang</title>
<meta name="description" content="Dokumentasi transparan perjalanan kebun kopi wakaf Ngantang: siklus fenologi, log aktivitas, data historis panen, dan proyeksi ke depan.">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Lora:ital,wght@0,400;0,600;1,400;1,600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Caveat:wght@400;500&display=swap" rel="stylesheet">
<style>

/* ══════════════════════════════════
   PALETTE R2 — EUCALYPTUS
══════════════════════════════════ */
:root {
  --dark:    #2e4040;
  --medium:  #5a9080;
  --light:   #a8c8bc;
  --accent:  #c4906a;
  --bg:      #f0f5f3;
  --bg-tint: #e8f4f0;
  --bg-deep: #d8eeea;
  --white:   #ffffff;
  --text:    #1e3030;
  --muted:   #5a7878;
  --ease:    cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}
img { max-width: 100%; display: block; }
a   { color: inherit; text-decoration: none; }

/* ── Lang visibility ── */
.lang-en { display: none; }
span.lang-en { display: none; }

/* ══════════════════════════════════
   NAVBAR
══════════════════════════════════ */
.navbar {
  position: sticky; top: 0; z-index: 200;
  background: var(--dark);
  border-bottom: 1px solid rgba(168,200,188,0.1);
}
.navbar-inner {
  display: flex; align-items: center; justify-content: space-between;
  height: 68px; padding: 0 2rem;
  max-width: 1200px; margin: 0 auto;
}
.navbar-logo {
  display: flex; align-items: center;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.82rem; font-weight: 800; color: #e8f4f0;
  text-decoration: none;
}
.brand-tag {
  padding: 0.18rem 0.6rem;
  border-radius: 6px;
  border: 1px solid var(--accent);
  box-shadow: 2px 2px 0px var(--accent);
  background: linear-gradient(135deg, rgba(90,144,128,0.22), rgba(90,144,128,0.1));
  color: #e8f4f0; white-space: nowrap;
}
.navbar-right { display: flex; align-items: center; gap: 0.5rem; }
.navbar-nav { display: flex; align-items: center; gap: 0.1rem; list-style: none; }
.navbar-nav li a {
  font-size: 0.78rem; font-weight: 500; color: #a8c8bc;
  padding: 0.35rem 0.7rem; border-radius: 6px;
  transition: color 0.15s, background 0.15s;
}
.navbar-nav li a:hover { color: #e8f4f0; background: rgba(255,255,255,0.07); }
.navbar-nav li a.active { color: #e8f4f0; font-weight: 700; }
.btn-nav-cta {
  background: var(--accent); color: #fff;
  padding: 0.35rem 0.9rem; border-radius: 20px;
  font-size: 0.75rem; font-weight: 700;
  margin-left: 0.4rem;
}
.nav-soon-cta {
  background: rgba(196,144,106,0.25); color: rgba(255,255,255,0.3);
  padding: 0.35rem 0.9rem; border-radius: 20px;
  font-size: 0.75rem; font-weight: 700;
  margin-left: 0.4rem; cursor: default; user-select: none;
}
.lang-btn {
  background: none; border: 1px solid rgba(168,200,188,0.35);
  color: #a8c8bc; padding: 0.22rem 0.6rem;
  border-radius: 5px; font-size: 0.72rem; font-weight: 600;
  cursor: pointer; transition: all 0.15s;
  font-family: 'Plus Jakarta Sans', sans-serif;
}
.lang-btn:hover, .lang-btn.active { background: var(--medium); color: #fff; border-color: var(--medium); }
.rwi-nav-badge {
  display: inline-flex; align-items: center; gap: 0.6rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(168,200,188,0.2);
  border-radius: 8px; padding: 0.35rem 0.7rem 0.35rem 0.45rem;
  flex-shrink: 0;
}
.rwi-logo-box {
  width: 96px; height: 48px; border-radius: 6px;
  background: #fff; display: flex; align-items: center;
  justify-content: center; flex-shrink: 0; overflow: hidden;
}
.rwi-logo-box img { width: 96px; height: 48px; object-fit: contain; display: block; }
.rwi-nav-text { line-height: 1.3; }
.rwi-nav-label { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: rgba(168,200,188,0.55); }
.rwi-nav-name  { font-size: 0.75rem; font-weight: 700; color: #d0e8e0; white-space: nowrap; }

/* ══════════════════════════════════
   HERO
══════════════════════════════════ */
.page-hero {
  background: var(--dark);
  padding: 4rem 2rem 3.5rem;
  position: relative; overflow: hidden;
}
.page-hero::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 50% 70% at 85% 30%, rgba(90,144,128,0.14) 0%, transparent 65%),
    radial-gradient(ellipse 30% 40% at 5% 85%, rgba(196,144,106,0.09) 0%, transparent 55%);
  pointer-events: none;
}
.page-hero-inner { max-width: 1200px; margin: 0 auto; position: relative; }
.page-hero-eyebrow {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: rgba(90,144,128,0.18);
  border: 1px solid rgba(168,200,188,0.28);
  color: var(--light);
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.28rem 0.85rem; border-radius: 20px;
  margin-bottom: 1.2rem;
}
.badge-dot-live {
  width: 7px; height: 7px; background: #5fca7c; border-radius: 50%;
  animation: blink-green 1.4s infinite;
}
@keyframes blink-green { 0%,100%{opacity:1} 50%{opacity:0.3} }
.page-hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.9rem, 3.8vw, 3rem);
  font-weight: 700; color: #e8f4f0;
  line-height: 1.26; margin-bottom: 1.1rem;
}
.page-hero h1 em { font-style: italic; color: var(--accent); }
.page-hero-lead {
  font-family: 'Lora', serif;
  font-size: 1rem; line-height: 1.8;
  color: rgba(168,200,188,0.8);
  max-width: 820px;
  text-align: justify;
}
.hero-stats {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1rem; margin-top: 2.4rem;
}
.hero-stat {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(168,200,188,0.18);
  border-radius: 12px; padding: 1rem 1.2rem;
  text-align: center;
}
.hero-stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem; font-weight: 300; font-style: italic;
  color: var(--accent); line-height: 1;
}
.hero-stat-label {
  font-size: 0.68rem; color: rgba(168,200,188,0.65);
  font-weight: 500; margin-top: 0.3rem; line-height: 1.4;
}

/* ══════════════════════════════════
   SECTION COMMONS
══════════════════════════════════ */
.section-inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
.section-label {
  font-size: 0.65rem; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--medium);
  margin-bottom: 0.4rem;
}
.section-label-light {
  font-size: 0.65rem; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--light);
  margin-bottom: 0.4rem;
}
.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.3rem, 2.5vw, 1.75rem);
  color: var(--dark); margin-bottom: 0.65rem; line-height: 1.3;
}
.section-title em { font-style: italic; color: var(--accent); }
.section-title-light {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.3rem, 2.5vw, 1.75rem);
  color: #e8f4f0; margin-bottom: 0.65rem; line-height: 1.3;
}
.section-title-light em { font-style: italic; color: var(--accent); }
.section-desc {
  font-family: 'Lora', serif;
  font-size: 0.92rem; color: var(--muted); line-height: 1.8;
  margin-bottom: 2rem; text-align: justify;
}
.section-desc-light {
  font-family: 'Lora', serif;
  font-size: 0.92rem; color: rgba(168,200,188,0.75); line-height: 1.8;
  margin-bottom: 2rem; text-align: justify;
}

/* ══════════════════════════════════
   NARASI SECTION
══════════════════════════════════ */
.narasi-section {
  padding: 3.5rem 2rem 3rem;
  border-bottom: 1px solid var(--bg-deep);
}
.narasi-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.8rem; margin-top: 2rem;
}
.narasi-card {
  background: var(--white);
  border: 1px solid var(--bg-deep);
  border-radius: 14px; padding: 1.5rem;
}
.narasi-icon { font-size: 1.8rem; margin-bottom: 0.8rem; }
.narasi-card-title {
  font-size: 0.95rem; font-weight: 700;
  color: var(--dark); margin-bottom: 0.5rem;
}
.narasi-card-desc {
  font-family: 'Lora', serif;
  font-size: 0.84rem; color: var(--muted); line-height: 1.75;
  text-align: justify;
}
.narasi-list {
  list-style: none; margin-top: 0.6rem;
  display: flex; flex-direction: column; gap: 0.35rem;
}
.narasi-list li {
  font-family: 'Lora', serif;
  font-size: 0.82rem; color: var(--muted);
  display: flex; align-items: flex-start; gap: 0.5rem;
}
.narasi-list li::before {
  content: '→';
  color: var(--medium); font-weight: 700;
  flex-shrink: 0; margin-top: 0.05rem;
}

/* ══════════════════════════════════
   STATUS TERKINI (INFOGRAFIK)
══════════════════════════════════ */
.status-section {
  padding: 3.5rem 2rem 3rem;
  background: var(--bg-tint);
  border-bottom: 1px solid var(--bg-deep);
}
.status-board {
  display: grid; grid-template-columns: 1fr 1.6fr 1fr;
  gap: 1.4rem; margin-top: 2rem;
}

/* Current Phase Card */
.phase-card {
  background: linear-gradient(145deg, #2a3c3c 0%, #233434 100%);
  border: 1.5px solid var(--accent);
  box-shadow: 5px 5px 0px var(--accent);
  border-radius: 16px; padding: 1.8rem 1.5rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; text-align: center;
}
.phase-card-eyebrow {
  font-size: 0.6rem; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--accent);
  margin-bottom: 0.8rem;
}
.phase-icon { font-size: 2.4rem; margin-bottom: 0.6rem; }
.phase-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.15rem; font-weight: 700;
  color: #e8f4f0; line-height: 1.3;
  margin-bottom: 0.4rem;
}
.phase-period {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem; font-style: italic;
  color: var(--accent); margin-bottom: 0.8rem;
}
.phase-badge-now {
  background: rgba(95,202,124,0.2);
  border: 1px solid rgba(95,202,124,0.4);
  color: #5fca7c;
  font-size: 0.6rem; font-weight: 800; letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.2rem 0.7rem; border-radius: 20px;
  display: inline-flex; align-items: center; gap: 0.4rem;
}
.dot-live-green {
  width: 6px; height: 6px; background: #5fca7c; border-radius: 50%;
  animation: blink-green 1.4s infinite;
}

/* Activity Tracker Card */
.activity-card {
  background: var(--white);
  border: 1px solid var(--bg-deep);
  border-radius: 16px; padding: 1.5rem;
}
.activity-card-title {
  font-size: 0.7rem; font-weight: 800; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--medium);
  margin-bottom: 1.1rem;
}
.act-list { display: flex; flex-direction: column; gap: 0.75rem; }
.act-item {
  display: flex; align-items: flex-start; gap: 0.75rem;
  padding: 0.65rem 0.8rem; border-radius: 10px;
  background: var(--bg);
}
.act-status {
  font-size: 0.58rem; font-weight: 800; letter-spacing: 0.07em;
  text-transform: uppercase; padding: 0.18rem 0.55rem;
  border-radius: 20px; white-space: nowrap; flex-shrink: 0;
  margin-top: 0.1rem;
}
.s-done    { background: rgba(90,144,128,0.15); color: #2e6050; }
.s-ongoing { background: rgba(196,144,106,0.15); color: #8a5030; }
.s-planned { background: rgba(90,120,120,0.12); color: var(--muted); }
.s-upcoming{ background: rgba(44,95,122,0.12); color: #2c5f7a; }
.act-label { font-size: 0.82rem; color: var(--text); font-weight: 500; line-height: 1.4; }
.act-sub   { font-size: 0.7rem; color: var(--muted); margin-top: 0.1rem; }

/* Milestone Card */
.milestone-card {
  background: linear-gradient(155deg, #f6fdfb 0%, #edf8f4 100%);
  border: 1.5px solid var(--accent);
  box-shadow: 4px 4px 0px var(--accent);
  border-radius: 16px; padding: 1.8rem 1.5rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; text-align: center;
}
.milestone-eyebrow {
  font-size: 0.6rem; font-weight: 800; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--muted);
  margin-bottom: 0.7rem;
}
.milestone-icon { font-size: 2rem; margin-bottom: 0.5rem; }
.milestone-name {
  font-family: 'Playfair Display', serif;
  font-size: 1rem; font-weight: 700;
  color: var(--dark); line-height: 1.3;
  margin-bottom: 0.35rem;
}
.milestone-when {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.35rem; font-style: italic;
  color: var(--accent); margin-bottom: 0.4rem;
}
.milestone-note {
  font-size: 0.72rem; color: var(--muted);
  font-family: 'Lora', serif; line-height: 1.5;
}

/* ══════════════════════════════════
   FENOLOGI SECTION
══════════════════════════════════ */
.fenologi-section {
  background: var(--dark);
  padding: 4rem 2rem;
  position: relative; overflow: hidden;
}
.fenologi-section::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 50% 80% at 50% 50%, rgba(90,144,128,0.08) 0%, transparent 70%);
  pointer-events: none;
}
.fenologi-layout {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4rem; align-items: center;
  margin-top: 2.5rem;
}
.fenologi-wheel-wrap { display: flex; justify-content: center; position: relative; }
.fenologi-svg { width: 320px; height: 320px; }
/* .fenologi-center-label defined in botanical decoration section below */
.center-month {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem; font-weight: 700;
  color: var(--accent); display: block; line-height: 1;
}
.center-year {
  font-size: 0.7rem; color: rgba(168,200,188,0.6);
  font-weight: 500; letter-spacing: 0.08em;
  text-transform: uppercase; display: block;
  margin-top: 0.15rem;
}
.center-phase-text {
  font-family: 'Lora', serif; font-style: italic;
  font-size: 0.72rem; color: var(--light);
  display: block; margin-top: 0.4rem;
  max-width: 90px;
}
.fenologi-legend { display: flex; flex-direction: column; gap: 0.9rem; }
.legend-item {
  display: flex; align-items: flex-start; gap: 0.9rem;
}
.legend-swatch {
  width: 14px; height: 14px; border-radius: 4px;
  flex-shrink: 0; margin-top: 0.15rem;
}
.legend-content {}
.legend-phase {
  font-size: 0.82rem; font-weight: 700;
  color: #e8f4f0; line-height: 1.3;
}
.legend-months {
  font-size: 0.68rem; color: rgba(168,200,188,0.55);
  font-family: 'Lora', serif; font-style: italic;
  margin-top: 0.1rem;
}
.legend-desc {
  font-size: 0.74rem; color: rgba(168,200,188,0.65);
  font-family: 'Lora', serif; line-height: 1.55;
  margin-top: 0.2rem; text-align: justify;
}
.fenologi-note {
  margin-top: 2.5rem;
  padding: 1rem 1.3rem;
  background: rgba(90,144,128,0.12);
  border: 1px solid rgba(168,200,188,0.2);
  border-radius: 10px;
  font-family: 'Lora', serif; font-style: italic;
  font-size: 0.82rem; color: rgba(168,200,188,0.7);
  line-height: 1.7; text-align: justify;
}

/* ══════════════════════════════════
   LOG AKTIVITAS
══════════════════════════════════ */
.log-section {
  padding: 3.5rem 2rem 4rem;
  border-bottom: 1px solid var(--bg-deep);
}
.log-year-tabs {
  display: flex; gap: 0.5rem; margin-top: 1.8rem; margin-bottom: 2rem;
  border-bottom: 2px solid var(--bg-deep);
  padding-bottom: 0;
}
.year-tab {
  padding: 0.5rem 1.2rem;
  font-size: 0.82rem; font-weight: 700;
  color: var(--muted); cursor: pointer;
  border-bottom: 3px solid transparent;
  margin-bottom: -2px; transition: all 0.15s;
  background: none; border-top: none; border-left: none; border-right: none;
  font-family: 'Plus Jakarta Sans', sans-serif;
  border-radius: 0;
}
.year-tab:hover { color: var(--dark); }
.year-tab.active {
  color: var(--dark); font-weight: 800;
  border-bottom-color: var(--accent);
}
.year-tab[data-year="2026"].active {
  color: #2a6e35;
  background: rgba(90,200,100,0.12);
  border: 1.5px solid rgba(70,170,80,0.45);
  border-bottom: 3px solid rgba(70,170,80,0.70);
  box-shadow: 3px 3px 0px rgba(70,170,80,0.25);
  border-radius: 6px 6px 0 0;
  padding: 0.5rem 1.2rem;
}
/* Active year 2026 — banner & section highlight */
.active-year-banner {
  display: flex; align-items: center; gap: 0.75rem;
  background: rgba(90,200,100,0.12);
  border: 1.5px solid rgba(70,170,80,0.40);
  box-shadow: 4px 4px 0px rgba(70,170,80,0.20);
  border-radius: 10px; padding: 0.75rem 1.1rem;
  margin-bottom: 1.5rem;
}
.active-year-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: rgba(50,160,65,0.80); flex-shrink: 0;
}
.active-year-label {
  font-size: 0.7rem; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; color: #2a6e35;
}
.active-year-desc {
  font-family: 'Lora', serif; font-size: 0.75rem;
  color: #3a7040; font-style: italic; margin-left: auto;
}
.year-content { display: none; }
.year-content.active { display: block; }

.phase-block { margin-bottom: 2.2rem; }
.phase-block-header {
  display: flex; align-items: center; gap: 0.7rem;
  margin-bottom: 1.1rem; padding-bottom: 0.7rem;
  border-bottom: 1px solid var(--bg-deep);
}
.phase-block-icon { font-size: 1.1rem; }
.phase-block-title {
  font-size: 0.85rem; font-weight: 800;
  color: var(--dark); text-transform: uppercase; letter-spacing: 0.06em;
}
.phase-block-period {
  font-family: 'Cormorant Garamond', serif;
  font-size: 0.85rem; font-style: italic;
  color: var(--muted); margin-left: auto;
}
.act-log-list { display: flex; flex-direction: column; gap: 0.7rem; }
.act-log-item {
  background: var(--white);
  border: 1px solid var(--bg-deep);
  border-radius: 10px; overflow: hidden;
  transition: border-color 0.15s;
}
.act-log-item:hover { border-color: rgba(196,144,106,0.35); }
.act-log-split {
  display: grid; grid-template-columns: 1fr 1fr;
}
.act-log-progress {
  display: flex; align-items: flex-start; gap: 1rem;
  padding: 0.85rem 1rem;
  border-right: 1px solid var(--bg-deep);
}
.act-log-theory {
  padding: 0.85rem 1.1rem;
  background: rgba(90,144,128,0.04); /* default — overridden by status classes */
}

/* ── Status-based background coloring ── */
/* Selesai: merah light — progress 40%, theory 20% */
.act-log-item.status-done .act-log-progress { background: rgba(210,60,60,0.40); }
.act-log-item.status-done .act-log-theory   { background: rgba(210,60,60,0.20); }
.act-log-item.status-done .act-log-progress { border-right-color: rgba(180,50,50,0.30); }

/* Berjalan: sage green — progress 60%, theory 40% */
.act-log-item.status-ongoing .act-log-progress { background: rgba(90,200,100,0.35); }
.act-log-item.status-ongoing .act-log-theory   { background: rgba(90,200,100,0.18); }
.act-log-item.status-ongoing .act-log-progress { border-right-color: rgba(70,170,80,0.30); }

/* Direncanakan: gelap/abu-abu muted — sangat subtle */
.act-log-item.status-planned .act-log-progress { background: rgba(100,120,120,0.10); }
.act-log-item.status-planned .act-log-theory   { background: rgba(100,120,120,0.06); }

/* Akan Datang: biru-teal muted */
.act-log-item.status-upcoming .act-log-progress { background: rgba(65,105,145,0.12); }
.act-log-item.status-upcoming .act-log-theory   { background: rgba(65,105,145,0.07); }

/* ── Terracotta Hangat — harmonisasi teks & aksen untuk status-done ── */
.act-log-item.status-done .act-log-status       { background: rgba(160,50,30,0.15) !important; color: #8b2e12 !important; }
.act-log-item.status-done .act-log-title        { color: #5c1e10; }
.act-log-item.status-done .act-log-detail       { color: #7a3020; }
.act-log-item.status-done .act-log-meta         { color: #7a3020; }
.act-log-item.status-done .act-log-meta strong  { color: #8b2e12; }
.act-log-item.status-done .theory-label         { color: #8b3525; }
.act-log-item.status-done .theory-body          { color: #6b2c1e; }
.act-log-item.status-done .theory-tag           { background: rgba(160,50,30,0.12); border-color: rgba(160,50,30,0.25); color: #7a2e18; }
.act-log-item.status-done .report-link          { color: #8b3525; border-bottom-color: rgba(160,50,30,0.30); }
.theory-label {
  font-size: 0.6rem; font-weight: 800; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--medium);
  margin-bottom: 0.45rem;
}
.theory-body {
  font-family: 'Lora', serif;
  font-size: 0.76rem; color: var(--muted); line-height: 1.7;
  text-align: justify;
}
.theory-tag {
  display: inline-block;
  background: rgba(90,144,128,0.1); border: 1px solid rgba(90,144,128,0.2);
  border-radius: 6px; padding: 0.18rem 0.55rem;
  font-size: 0.63rem; color: #2e6050; font-weight: 700;
  font-family: 'Plus Jakarta Sans', sans-serif;
  margin-top: 0.45rem; margin-right: 0.3rem;
}
.act-log-status {
  font-size: 0.58rem; font-weight: 800; letter-spacing: 0.07em;
  text-transform: uppercase; padding: 0.2rem 0.55rem;
  border-radius: 20px; white-space: nowrap; flex-shrink: 0;
  margin-top: 0.15rem;
}
.act-log-body { flex: 1; }
.act-log-title {
  font-size: 0.86rem; font-weight: 600;
  color: var(--text); line-height: 1.4;
}
.act-log-detail {
  font-family: 'Lora', serif;
  font-size: 0.77rem; color: var(--muted); line-height: 1.65;
  margin-top: 0.2rem; text-align: justify;
}
.act-log-meta {
  font-size: 0.68rem; color: var(--muted);
  white-space: nowrap; flex-shrink: 0; margin-top: 0.15rem;
  text-align: right; min-width: 90px;
}
.act-log-meta strong { color: var(--accent); display: block; font-size: 0.72rem; }
.report-link {
  display: inline-flex; align-items: center; gap: 0.3rem;
  font-size: 0.65rem; font-weight: 700;
  color: var(--medium); margin-top: 0.35rem;
  padding: 0.1rem 0; border-bottom: 1px solid rgba(90,144,128,0.3);
  cursor: pointer; transition: color 0.15s;
}
.report-link:hover { color: var(--dark); }

/* year summary bar */
.year-summary {
  display: flex; gap: 1rem; margin-bottom: 1.8rem; flex-wrap: wrap;
}
.year-sum-pill {
  background: var(--bg-tint);
  border: 1px solid var(--bg-deep);
  border-radius: 8px; padding: 0.5rem 1rem;
  font-size: 0.75rem; color: var(--muted);
}
.year-sum-pill strong { color: var(--accent); }

/* ══════════════════════════════════
   DATA HISTORIS PANEN
══════════════════════════════════ */
.harvest-section {
  padding: 3.5rem 2rem 4rem;
  background: var(--bg-tint);
}
.harvest-track {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
  gap: 0.5rem; align-items: center;
  margin-top: 2rem;
}
.harvest-node {
  background: var(--white);
  border: 1px solid var(--bg-deep);
  border-radius: 12px; padding: 1rem 1.1rem;
  box-shadow: 3px 3px 0 var(--bg-deep);
  display: flex; flex-direction: column;
}
.harvest-kg {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.55rem; font-style: italic;
  color: var(--accent); line-height: 1.1;
  margin-bottom: 0.45rem;
}
.harvest-year {
  font-size: 0.65rem; font-weight: 800; letter-spacing: 0.09em;
  text-transform: uppercase; color: var(--muted);
  margin-bottom: 0.3rem;
}
.harvest-bar-wrap {
  width: 100%; height: 8px;
  background: var(--bg-deep); border-radius: 4px;
  overflow: visible; margin-bottom: 0.45rem;
  position: relative;
}
.harvest-bar {
  height: 100%; border-radius: 4px;
  transition: width 0.6s var(--ease);
}
.harvest-bar.b-no-data {
  width: 8%;
  background: repeating-linear-gradient(90deg, var(--light) 0px, var(--light) 4px, transparent 4px, transparent 8px);
  border: none;
}
.harvest-bar.b-2024 { width: 34%; background: var(--light); }
.harvest-bar.b-2025 { width: 94%; background: var(--medium); }
.harvest-bar.b-target {
  width: 100%; background: transparent;
  border: 2px dashed var(--accent); border-radius: 4px; height: 8px;
  box-sizing: border-box;
}
.harvest-note { font-size: 0.65rem; color: var(--muted); font-style: italic; }
.harvest-tag {
  font-size: 0.57rem; font-weight: 800; letter-spacing: 0.07em;
  text-transform: uppercase; padding: 0.14rem 0.5rem;
  border-radius: 20px; margin-top: 0.45rem;
  display: inline-block; align-self: flex-start;
}
.t-nodata  { background: rgba(90,120,120,0.10); color: var(--muted); }
.t-start   { background: rgba(90,144,128,0.12); color: #2e6050; }
.t-growth  { background: rgba(90,144,128,0.22); color: #1e5040; }
.t-target  { background: rgba(196,144,106,0.15); color: #7a4a1a; }
.harvest-arrow {
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem; color: var(--accent);
  line-height: 1; padding: 0 0.1rem;
}
.harvest-context {
  margin-top: 2rem;
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
.harvest-ctx-card {
  background: var(--white);
  border: 1px solid var(--bg-deep);
  border-radius: 12px; padding: 1rem 1.2rem;
  text-align: center;
}
.ctx-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem; font-style: italic;
  color: var(--accent);
}
.ctx-label { font-size: 0.7rem; color: var(--muted); margin-top: 0.2rem; line-height: 1.45; }

/* ══════════════════════════════════
   FOOTER
══════════════════════════════════ */
.footer { background: #1a2e2e; padding: 1.8rem 2rem; }
.footer-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  gap: 1.5rem; flex-wrap: wrap;
}
.footer-verse {
  font-family: 'Playfair Display', serif;
  font-style: italic; font-size: 0.78rem;
  color: rgba(168,200,188,0.45); line-height: 1.7;
  max-width: 440px;
}
.footer-brand { font-size: 0.75rem; font-weight: 800; color: rgba(168,200,188,0.5); margin-bottom: 0.2rem; }
.footer-meta { font-size: 0.68rem; color: rgba(168,200,188,0.3); line-height: 1.6; text-align: right; }

/* ══════════════════════════════════
   RESPONSIVE
══════════════════════════════════ */
@media (max-width: 960px) {
  .fenologi-layout { grid-template-columns: 1fr; gap: 2rem; }
  .fenologi-wheel-wrap { justify-content: center; }
  .status-board { grid-template-columns: 1fr; }
  .harvest-track { grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr; gap: 0.4rem; }
  .narasi-grid { grid-template-columns: 1fr; }
  .harvest-context { grid-template-columns: 1fr; }
  .act-log-split { grid-template-columns: 1fr; }
  .act-log-progress { border-right: none; border-bottom: 1px solid var(--bg-deep); }
}
@media (max-width: 768px) {
  .harvest-track { grid-template-columns: 1fr 1fr; row-gap: 0.8rem; }
  .harvest-arrow { display: none; }
  .hero-stats { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .navbar-nav { display: none; }
  .rwi-nav-badge { display: none; }
  .page-hero { padding: 2.5rem 1.2rem 2rem; }
  .hero-stats { grid-template-columns: repeat(2, 1fr); }
  .footer-inner { flex-direction: column; }
  .footer-meta { text-align: left; }
  .harvest-track { grid-template-columns: repeat(2, 1fr); }
}

/* ── Paragraf justified ── */
p, .page-hero-lead, .section-desc, .section-desc-light,
.narasi-card-desc, .act-log-detail,
.legend-desc, .fenologi-note { text-align: justify; }

/* ── Fenologi botanical decoration ── */
.feno-bg-leaf {
  position: absolute; pointer-events: none; z-index: 0;
  opacity: 0.07;
}
.feno-leaf-tr { right: -50px; top: -40px; width: 300px; transform: rotate(18deg); }
.feno-leaf-bl { left: -45px; bottom: 10px; width: 250px; transform: rotate(-38deg) scaleX(-1); }
.feno-leaf-br { right: 10%; bottom: -30px; width: 170px; transform: rotate(12deg); }
.fenologi-layout { position: relative; z-index: 1; }
.fenologi-center-label {
  position: absolute;
  top: 50%; left: 50%; transform: translate(-50%, -50%);
  text-align: center; pointer-events: none;
}

</style>
</head>
<body>

<!-- ══ NAVBAR ══ -->
<header class="navbar">
  <div class="navbar-inner">
    <a href="index.html" class="navbar-logo">
      <span class="brand-tag">Wakaf Produktif Kebun Kopi</span>
    </a>
    <div class="navbar-right">
      <nav>
        <ul class="navbar-nav">
