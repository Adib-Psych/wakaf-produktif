    </div>
  </div>
</section>

<!-- ══ FOOTER ══ -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-verse">
      <span class="lang-id">"Apabila manusia meninggal dunia, terputuslah amalnya kecuali tiga perkara:<br>sedekah jariyah, ilmu yang bermanfaat, dan anak saleh yang mendoakannya."<br><small style="font-style:normal;font-size:.68rem;letter-spacing:.1em;opacity:.6;">— HR. Muslim</small></span>
      <span class="lang-en">"When a person dies, their deeds come to an end except for three:<br>ongoing charity, beneficial knowledge, and a righteous child who prays for them."<br><small style="font-style:normal;font-size:.68rem;letter-spacing:.1em;opacity:.6;">— Hadith (Sahih Muslim)</small></span>
    </div>
    <div>
      <div class="footer-brand">Wakaf Produktif Kebun Kopi</div>
      <div class="footer-meta">
        Lembaga Nazir: Rumah Wakaf Indonesia<br>
        Dusun Kebonsari, Ngantang, Malang, Jawa Timur
      </div>
    </div>
  </div>
</footer>

<script>
/* ══ LANGUAGE TOGGLE ══ */
const INLINE_TAGS = new Set(['span','em','strong','i','b','small','sup','sub']);
const INLINE_BLOCK_TAGS = new Set(['a']);

function getDisplayType(el) {
  const tag = el.tagName.toLowerCase();
  if (INLINE_TAGS.has(tag))       return 'inline';
  if (INLINE_BLOCK_TAGS.has(tag)) return 'inline-block';
  return 'block';
}

function setLang(lang) {
  const hide = lang === 'id' ? 'en' : 'id';
  localStorage.setItem('lang', lang);
  document.querySelectorAll('a[href]').forEach(function(a) {
    var h = a.getAttribute('href');
    if (!h || h.indexOf('http') === 0 || h.indexOf('#') === 0 || h.indexOf('mailto') === 0) return;
    a.setAttribute('href', h.split('?')[0] + '?lang=' + lang);
  });
  document.querySelectorAll('.lang-' + hide).forEach(el => { el.style.display = 'none'; });
  document.querySelectorAll('.lang-' + lang).forEach(el => { el.style.display = getDisplayType(el); });
  document.getElementById('btn-id').classList.toggle('active', lang === 'id');
  document.getElementById('btn-en').classList.toggle('active', lang === 'en');
}

document.addEventListener('DOMContentLoaded', function() {
  buildTheoryColumns();
  buildFenologi();
  setLang(new URLSearchParams(location.search).get('lang') || localStorage.getItem('lang') || 'id');
});

/* ══ THEORY COLUMNS ══ */
var theoryData = {
  '2024': [
    {
      id: 'Gulma bersaing langsung dengan kopi untuk cahaya, air tanah, dan nitrogen. Kanopi yang tertutup gulma dapat menekan fotosintesis pohon hingga 30–40%, dan gulma yang membusuk meningkatkan kelembapan berlebih yang menjadi media jamur patogen. Pembersihan awal adalah prasyarat dasar — tanpa sanitasi lahan, tidak ada intervensi pemupukan yang dapat bekerja efektif.',
      en: 'Weeds directly compete with coffee for light, soil water, and nitrogen. A weed-covered canopy can suppress tree photosynthesis by 30–40%, while decaying weeds increase excess moisture that breeds fungal pathogens. Initial clearing is the baseline prerequisite — without land sanitation, no fertilization intervention can work effectively.',
      tags: ['Sanitasi Kebun', 'Prasyarat Intervensi']
    },
    {
      id: 'Produktivitas 0,11 KG/pohon berada di bawah 30% rata-rata nasional robusta Indonesia (0,4–0,8 KG/pohon). Angka ini mencerminkan kondisi pohon yang kelelahan: cabang primer menua mendominasi, beban buah terpusat di ujung, dan tanah belum dipulihkan. Sebagai baseline pertama, angka ini berharga — membuktikan bahwa kebun masih produktif dan memiliki kapasitas tumbuh dengan intervensi yang tepat.',
      en: 'Productivity of 0.11 KG/tree falls below 30% of Indonesia\'s national robusta average (0.4–0.8 KG/tree). This reflects exhausted tree conditions: aging primary branches dominate, fruit load is concentrated at branch tips, and soil is unrestored. As the first baseline, this figure is valuable — it proves the garden is still productive and has growth capacity with proper intervention.',
      tags: ['Baseline 0,11 KG/Pohon', 'Cabang Primer Menua']
    },
    {
      id: 'Kegagalan replanting umumnya disebabkan oleh tiga faktor: transplant shock akibat perubahan mendadak kondisi lingkungan, pemilihan waktu yang tidak tepat (musim kering), dan bibit yang tidak melalui proses hardening off. Bibit kopi muda sangat sensitif terhadap fluktuasi kelembapan tanah. Pelajaran kunci: replanting ideal di awal musim hujan, dengan naungan sementara 3–4 bulan dan penyiraman harian selama masa adaptasi.',
      en: 'Replanting failures are typically caused by three factors: transplant shock from sudden environmental changes, poor timing (dry season), and seedlings without proper hardening off. Young coffee seedlings are highly sensitive to soil moisture fluctuations. Key lesson: ideal replanting is done at the rainy season onset, with 3–4 months of temporary shade and daily watering during the adaptation period.',
      tags: ['Transplant Shock', 'Timing: Awal Musim Hujan']
    }
  ],
  '2025': [
    {
      id: 'Lonjakan 346% ini adalah respons kumulatif sanitasi lahan 2024: kanopi terbuka meningkatkan penetrasi cahaya, akar pulih dari tekanan gulma, dan pohon mengalokasikan lebih banyak fotosintat ke buah. Produktivitas 0,31 KG/pohon mendekati rata-rata nasional mengkonfirmasi potensi genetik tanaman yang kuat. Dengan intervensi nutrisi intensif, target realistis berikutnya adalah 0,5–0,6 KG/pohon atau setara 457–549 KG total.',
      en: 'This 346% surge is a cumulative response to 2024 land sanitation: open canopy increased light penetration, roots recovered from weed pressure, and trees allocated more photosynthate to fruit. Productivity of 0.31 KG/tree approaching national average confirms strong genetic potential. With intensive nutritional intervention, the next realistic target is 0.5–0.6 KG/tree or 457–549 KG total.',
      tags: ['Efek Kumulatif Sanitasi', 'Target: 0,5+ KG/Pohon']
    },
    {
      id: 'Dari perspektif agronomi jangka panjang, kepastian status lahan adalah prasyarat untuk program rehabilitasi multi-tahun yang efektif. Investasi dalam perbaikan tanah, replanting, dan peremajaan pohon baru menghasilkan dampak nyata setelah 3–5 tahun — horizon yang hanya feasible jika pengelolaan terjamin. Status wakaf produktif juga membuka akses ke riset akademik dan dukungan institusional yang tidak tersedia untuk kebun biasa.',
      en: 'From a long-term agronomy perspective, land tenure certainty is a prerequisite for effective multi-year rehabilitation programs. Investment in soil improvement, replanting, and tree rejuvenation only yields meaningful results after 3–5 years — a horizon only feasible with guaranteed management. Productive waqf status also opens access to academic research and institutional support unavailable to ordinary gardens.',
      tags: ['Horizon Rehabilitasi 3–5 Tahun', 'Wakaf = Jaminan Keberlanjutan']
    }
  ],
  '2026': [
    {
      id: 'Di fase Pemulihan (Januari), pohon kopi dalam kondisi stres fisiologis pasca-panen. Nitrogen (N) dari NPK dan Ponska merangsang pertumbuhan vegetatif dan pembentukan tunas baru. Fosfor (P) dari Fertiphos kritis untuk perkembangan akar dan transfer energi seluler. Boron dari Karate Plus sering diabaikan namun vital: defisiensi boron adalah penyebab utama gugurnya bunga kopi secara prematur. Aplikasi di musim hujan memaksimalkan penyerapan akar melalui irigasi alami.',
      en: 'In the Recovery phase (January), coffee trees are in post-harvest physiological stress. Nitrogen (N) from NPK and Ponska stimulates vegetative growth and new bud formation. Phosphorus (P) from Fertiphos is critical for root development and cellular energy transfer. Boron from Karate Plus is often overlooked but vital: boron deficiency is the primary cause of premature coffee flower drop. Rainy season application maximizes root absorption through natural irrigation.',
      tags: ['N untuk Vegetatif', 'Boron = Anti-Gugur Bunga']
    },
    {
      id: 'Penggemburan dengan garpu memotong sebagian akar serabut tua secara terkontrol — respons fisiologis pohon adalah membentuk akar baru yang lebih muda, aktif, dan efisien menyerap hara. Pada tanah berpasir, bahan organik dari kompos adalah satu-satunya cara meningkatkan Kapasitas Tukar Kation (KTK) — kemampuan tanah mengikat mineral bagi akar. Kompos ayam petelur kaya nitrogen organik dan mikroba tanah yang mengaktifkan siklus hara alami.',
      en: 'Forking cuts older fibrous roots in a controlled way — the tree\'s physiological response is to form new, younger, more nutrient-efficient roots. In sandy soil, organic matter from compost is the only way to increase the soil\'s Cation Exchange Capacity (CEC) — its ability to bind minerals for root uptake. Poultry compost is rich in organic nitrogen and soil microbes that activate the natural nutrient cycle.',
      tags: ['Root Pruning → Akar Baru', 'KTK Tanah Berpasir']
    },
    {
      id: 'Kopi robusta sangat sensitif terhadap stres air di fase pembungaan (Februari–Maret). Bahkan kekeringan singkat 3–5 hari pada periode ini dapat memicu gugurnya bunga secara massal — fenomena yang dikenal sebagai flower drop. Konsistensi jadwal penyemprotan nutrisi setiap 10 hari, yang logistis hanya mungkin dengan akses air terjamin, adalah fondasi dari seluruh program intervensi yang direncanakan.',
      en: 'Robusta coffee is highly sensitive to water stress during the flowering phase (February–March). Even brief 3–5 day droughts during this period can trigger mass flower drop. A consistent 10-day nutrient spray schedule, logistically possible only with guaranteed water access, is the foundation of the entire planned intervention program.',
      tags: ['Cegah Flower Drop', 'Jadwal Konsisten 10 Hari']
    },
    {
      id: 'Fish extract mengandung asam amino bebas, sitokinin alami, dan auksin — hormon pertumbuhan yang mendorong transisi dari fase vegetatif ke generatif (pembungaan). Di fase Vegetatif→Buah Muda (Maret–April), aplikasi ini membantu bunga yang sudah terbentuk berkembang menjadi putik dan buah muda. Kandungan nitrogen organik juga mempercepat pemulihan jaringan daun pasca-panen.',
      en: 'Fish extract contains free amino acids, natural cytokinins, and auxins — growth hormones that drive the transition from vegetative to generative phase (flowering). In the Vegetative→Young Fruit phase (March–April), this application helps formed flowers develop into buds and young fruit. The organic nitrogen content also accelerates leaf tissue recovery after harvest.',
      tags: ['Sitokinin → Transisi Bunga', 'Asam Amino Organik']
    },
    {
      id: 'TDS (Total Dissolved Solids) tanah mengukur konsentrasi ion mineral terlarut — indikator langsung ketersediaan hara bagi akar. Hasil negatif di seluruh 5 titik pada tanah berpasir mengkonfirmasi defisiensi mineral. pH 6–7 sebenarnya ideal untuk robusta (optimal 5,5–6,5), artinya masalah bukan keasaman — melainkan rendahnya kandungan bahan organik sebagai reservoir mineral. Program pupuk organik berkelanjutan adalah solusi utama.',
      en: 'Soil TDS (Total Dissolved Solids) measures dissolved mineral ion concentration — a direct indicator of nutrient availability to roots. Negative results at all 5 sampling points in sandy soil confirms mineral deficiency. pH 6–7 is actually ideal for robusta (optimal 5.5–6.5), meaning the issue is not acidity — but low organic matter content that serves as the mineral reservoir. A sustained organic fertilization program is the primary solution.',
      tags: ['TDS Negatif = Defisiensi Mineral', 'pH 6–7 Sudah Optimal']
    },
    {
      id: 'Pada fase Pembentukan Buah (April–Mei), kebutuhan nutrisi bergeser dari N ke P dan K. Fosfor (P) mendukung sintesis sel buah dan produksi ATP untuk pengisian biji. Kalium (K) mengatur transport gula dari daun ke buah — meningkatkan brix dan kualitas citarasa biji kopi. Pupuk kandang menyediakan P dan K secara slow-release, jauh lebih aman dari pupuk kimia yang berisiko membakar akar di tanah berpasir yang miskin organik.',
      en: 'In the Fruit Formation phase (April–May), nutritional needs shift from N to P and K. Phosphorus (P) supports fruit cell synthesis and ATP production for seed filling. Potassium (K) regulates sugar transport from leaves to fruit — increasing brix and coffee bean flavor quality. Manure provides P and K as slow-release, far safer than chemical fertilizers that risk burning roots in organically depleted sandy soil.',
      tags: ['P & K untuk Buah Muda', 'Slow-Release = Aman Tanah Berpasir']
    },
    {
      id: 'Pruning di fase Buah Muda — bukan saat bunga aktif — aman dilakukan dan memberi manfaat ganda: meningkatkan penetrasi cahaya ke cabang produktif dan mengurangi beban karbon pohon. Sinar matahari langsung ke buah muda meningkatkan akumulasi gula dan konsentrasi kafein. Cabang primer tua yang hanya berbuah di ujung adalah kandidat utama pemangkasan — memfokuskan nutrisi ke cabang sekunder yang lebih muda dan produktif.',
      en: 'Pruning during the Young Fruit phase — not during active flowering — is safe and provides dual benefits: increased sunlight penetration to productive branches and reduced tree carbon load. Direct sunlight on young fruit increases sugar accumulation and caffeine concentration. Old primary branches that only fruit at their tips are prime pruning candidates — redirecting nutrients to younger, more productive secondary branches.',
      tags: ['Penetrasi Cahaya ke Buah', 'Cabang Sekunder > Cabang Tua']
    },
    {
      id: 'Hama utama kopi robusta Jawa Timur: Coffee Berry Borer (Hypothenemus hampei) yang mengebor masuk ke biji dalam buah, karat daun Hemileia vastatrix, dan antraknos buah Colletotrichum. CBB saja dapat menyebabkan kerugian 30–80% dari total panen jika tidak dikendalikan sejak dini. Identifikasi di fase Buah Muda adalah timing kritis — pengendalian biologis masih sangat efektif, jauh sebelum buah matang dan opsi menjadi terbatas.',
      en: 'Primary East Java robusta pests: Coffee Berry Borer (Hypothenemus hampei) that bores into beans inside fruit, leaf rust Hemileia vastatrix, and anthracnose Colletotrichum. CBB alone can cause 30–80% harvest loss if not controlled early. Identification in the Young Fruit phase is critical timing — biological control is still highly effective, long before fruit matures and control options become limited.',
      tags: ['CBB = Risiko 30–80%', 'Identifikasi Dini Kritis']
    },
    {
      id: 'Pemetikan selektif (selective picking) menghasilkan biji dengan kadar gula (brix) lebih tinggi dan profil rasa lebih kompleks dibanding strip picking. Robusta dipetik saat merah penuh untuk kualitas optimal. Empat ronde diperlukan karena buah dalam satu cluster tidak masak serentak — interval optimal 10–14 hari antar ronde memaksimalkan volume buah merah yang dipetik. Pencatatan data per ronde membangun arsip historis panen yang berharga untuk perencanaan tahun-tahun berikutnya.',
      en: 'Selective picking produces beans with higher sugar content (brix) and more complex flavor compared to strip picking. Robusta is picked at full red for optimal quality. Four rounds are needed because fruit within a cluster does not ripen simultaneously — optimal 10–14 day intervals between rounds maximize red-ripe fruit volume. Per-round data recording builds a valuable harvest archive for future planning.',
      tags: ['Selective Picking = Kualitas', 'Interval 10–14 Hari/Ronde']
    },
    {
      id: 'Pruning total 30–50 cm dari batang (stumping) adalah teknik rejuvenasi standar untuk kopi berumur >10 tahun dengan cabang primer yang menua. Pohon yang di-stump membentuk tunas air (water shoots) dari batang utama yang sehat — tunas inilah yang menjadi cabang produktif generasi berikutnya. Dibutuhkan 8–12 bulan dari stumping hingga pohon siap berbunga kembali: stumping September–Oktober 2026 memproyeksikan produksi optimal pada 2027–2028.',
      en: 'Full pruning 30–50 cm from the trunk (stumping) is the standard rejuvenation technique for coffee >10 years old with aging primary branches. Stumped trees form water shoots from the healthy main trunk — these become the next generation of productive branches. It takes 8–12 months from stumping until trees are ready to flower again: September–October 2026 stumping projects optimal production in 2027–2028.',
      tags: ['Stumping = Rejuvenasi', '8–12 Bulan ke Panen Baru']
    },
    {
      id: 'Data soil profile komparatif — antara kondisi awal (April 2026) dan pasca-satu siklus intervensi penuh (Oktober 2026) — memiliki nilai ilmiah signifikan untuk agronomi kopi organik. Perubahan TDS, pH, kandungan organik, dan produktivitas pohon dapat mengkuantifikasi dampak nyata program rehabilitasi. Data ini terbuka untuk peneliti, akademisi, dan program wakaf produktif lain yang ingin mereplikasi pendekatan ini.',
      en: 'Comparative soil profile data — between initial conditions (April 2026) and after one full intervention cycle (October 2026) — holds significant scientific value for organic coffee agronomy. Changes in TDS, pH, organic content, and tree productivity can quantify the real impact of the rehabilitation program. This data is open to researchers, academics, and other productive waqf programs wishing to replicate this approach.',
      tags: ['Data Longitudinal Terbuka', 'Soil Health Before/After']
    }
  ]
};

function buildTheoryColumns() {
  ['2024', '2025', '2026'].forEach(function(year) {
    var section = document.getElementById('year-' + year);
    if (!section) return;
    var items = section.querySelectorAll('.act-log-item');
    var theories = theoryData[year] || [];
    items.forEach(function(item, i) {
      var theory = theories[i];
      if (!theory) return;
      // Deteksi status sebelum innerHTML diganti
      var statusEl = item.querySelector('.act-log-status');
      var statusCls = 'status-planned';
      if (statusEl) {
        if (statusEl.classList.contains('s-done'))       statusCls = 'status-done';
        else if (statusEl.classList.contains('s-ongoing'))  statusCls = 'status-ongoing';
        else if (statusEl.classList.contains('s-upcoming')) statusCls = 'status-upcoming';
      }
      item.classList.add(statusCls);
      var orig = item.innerHTML;
      var tagsHtml = theory.tags.map(function(t) {
        return '<span class="theory-tag">' + t + '</span>';
      }).join('');
      item.innerHTML =
        '<div class="act-log-split">' +
          '<div class="act-log-progress">' + orig + '</div>' +
          '<div class="act-log-theory">' +
            '<div class="theory-label lang-id">🔬 Panduan Teoritis</div>' +
            '<div class="theory-label lang-en">🔬 Theoretical Context</div>' +
            '<p class="theory-body lang-id">' + theory.id + '</p>' +
            '<p class="theory-body lang-en">' + theory.en + '</p>' +
            '<div>' + tagsHtml + '</div>' +
          '</div>' +
        '</div>';
    });
  });
}

/* ══ YEAR TAB SWITCHER ══ */
function switchYear(year) {
  document.querySelectorAll('.year-content').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.year-tab').forEach(el => el.classList.remove('active'));
  document.getElementById('year-' + year).classList.add('active');
  document.querySelector('[data-year="' + year + '"]').classList.add('active');
}

/* ══ FENOLOGI WHEEL ══ */
function buildFenologi() {
  const svg = document.getElementById('fenologi-svg');
  if (!svg) return;

  const CX = 160, CY = 160, R1 = 78, R2 = 126, R_LABEL = 144;
  const currentMonth = 3; // April = index 3 (0=Jan)

  const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
  const phaseColors = [
    '#7a9e96', // Jan  — Pemulihan
    '#5a9080', // Feb  — Vegetatif
    '#5a9080', // Mar  — Vegetatif
    '#7db848', // Apr  — Buah Muda (current)
    '#7db848', // Mei  — Buah Muda
    '#c8a840', // Jun  — Pematangan
    '#c4906a', // Jul  — PANEN
    '#c4906a', // Agt  — PANEN
    '#3d7868', // Sep  — Post-Panen
    '#3d7868', // Okt  — Post-Panen
    '#7a9e96', // Nov  — Pemulihan
    '#7a9e96', // Des  — Pemulihan
  ];

  let html = '';

  // Draw gap between segments
  const GAP = 1.5; // degrees

  for (let i = 0; i < 12; i++) {
    const startDeg = i * 30 - 90 + GAP / 2;
    const endDeg   = (i + 1) * 30 - 90 - GAP / 2;
    const s = startDeg * Math.PI / 180;
    const e = endDeg   * Math.PI / 180;

    const x1 = CX + R2 * Math.cos(s);
    const y1 = CY + R2 * Math.sin(s);
    const x2 = CX + R2 * Math.cos(e);
    const y2 = CY + R2 * Math.sin(e);
    const x3 = CX + R1 * Math.cos(e);
    const y3 = CY + R1 * Math.sin(e);
    const x4 = CX + R1 * Math.cos(s);
    const y4 = CY + R1 * Math.sin(s);

    const isNow = (i === currentMonth);
    const opacity  = isNow ? 1 : 0.72;
    const stroke   = isNow ? '#ffffff' : 'rgba(46,64,64,0.6)';
    const sw       = isNow ? 2.5 : 0.8;
    const color    = phaseColors[i];

    html += `<path d="M${f(x1)},${f(y1)} A${R2},${R2},0,0,1,${f(x2)},${f(y2)} L${f(x3)},${f(y3)} A${R1},${R1},0,0,0,${f(x4)},${f(y4)} Z"
      fill="${color}" opacity="${opacity}" stroke="${stroke}" stroke-width="${sw}"/>`;

    // Label
    const midDeg = i * 30 - 90 + 15;
    const midRad = midDeg * Math.PI / 180;
    const lx = CX + R_LABEL * Math.cos(midRad);
    const ly = CY + R_LABEL * Math.sin(midRad);
    const fs   = isNow ? 9.5 : 8;
    const fw   = isNow ? 'bold' : 'normal';
    const fc   = isNow ? '#c4906a' : 'rgba(168,200,188,0.7)';

    html += `<text x="${f(lx)}" y="${f(ly)}" text-anchor="middle" dominant-baseline="middle"
      font-size="${fs}" font-weight="${fw}" fill="${fc}"
      font-family="Plus Jakarta Sans, sans-serif">${months[i]}</text>`;

    // Current month glow ring
    if (isNow) {
      const glowR = (R1 + R2) / 2;
      html += `<circle cx="${CX}" cy="${CY}" r="${glowR}" fill="none"
        stroke="rgba(125,184,72,0.25)" stroke-width="${R2-R1}" opacity="0.3"/>`;
    }
  }

  // Inner circle background
  html = `<circle cx="${CX}" cy="${CY}" r="${R1-1}" fill="#233434" opacity="0.95"/>` + html;

  // "Now" pointer
  const nowDeg = currentMonth * 30 - 90 + 15;
  const nowRad = nowDeg * Math.PI / 180;
  const px = CX + (R1 - 8) * Math.cos(nowRad);
  const py = CY + (R1 - 8) * Math.sin(nowRad);
  html += `<circle cx="${f(px)}" cy="${f(py)}" r="4" fill="#7db848" opacity="0.9"/>`;

  svg.innerHTML = html;
}

function f(n) { return n.toFixed(1); }
</script>
</body>
</html>
