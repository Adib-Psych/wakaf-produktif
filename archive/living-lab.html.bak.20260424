          <li><a href="living-lab.html" class="active">Living Lab</a></li>
          <li><a href="latar-belakang.html"><span class="lang-id">Kisah</span><span class="lang-en">Story</span></a></li>
          <li><a href="kontak.html"><span class="lang-id">Kontak</span><span class="lang-en">Contact</span></a></li>
