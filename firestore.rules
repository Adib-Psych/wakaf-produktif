// ============================================================
// Firestore Security Rules — Wakaf Ngantang
// Updated 17 Mei 2026 — Phase 1 production rules
// REV 26 Jun 2026: + worker baru YASIR/KAMTO/HARNI/MAKMIS ke allowlist laporan (create+update) + workers.
//   Casus: laporan Mak Mis(MAKMIS)/Mba Harmi(HARNI) ditolak ("sync 0") krn pelapor tak ada di allowlist lama.
// REV 27 Jun 2026: + CHRISTO (kelewat di REV 26 -> "sync 0" sama spt Mak Mis/Harmi, kasus gabungan).
//   REFACTOR ke SINGLE-SOURCE function isFieldWorker()/isLaporanPelapor() — tambah pekerja baru CUKUP 1 tempat,
//   bukan 3 array inline terpisah (laporan create + laporan update + workers) yang rawan kelewat.
//
// DEPLOY: Paste isi file ini ke Firebase Console:
//   Firebase Console → Build → Firestore Database → Rules tab → Edit
//   Click "Publish" untuk apply.
//
// Phase 1 strategy (locked 17 Mei 2026):
//   - Worker tokens (KUMPUL/YIT/ANTO) bertindak sebagai shared key
//     untuk CREATE laporan. Tidak ada Firebase Auth dulu — keep simple.
//   - Anybody bisa READ collection laporan (Wakif dashboard butuh, dan
//     Living Lab future fetch akan butuh). Privacy NOT enforced di Phase 1.
//   - UPDATE/DELETE locked — hanya bisa via Firebase Console (Wakif manual).
//   - Schema validation: pelapor harus salah satu dari 3 worker valid +
//     created_at + tanggal wajib + size limit.
//
// Phase 2 (later, when Adib ready): migrate ke Firebase Auth + custom claims
// untuk role-based access (wakif full, worker scoped, public limited).
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Worker allowlist — SINGLE SOURCE (REV 27 Jun 2026) =====
    // ⭐ Tambah pekerja baru CUKUP di isFieldWorker() di bawah — otomatis berlaku ke laporan + workers.
    //    Lesson 27 Jun: CHRISTO sempat kelewat krn dulu ada 3 array inline terpisah.
    function isFieldWorker(tok) {
      return tok in ['KUMPUL', 'YIT', 'ANTO', 'YASIR', 'KAMTO', 'HARNI', 'MAKMIS', 'CHRISTO'];
    }
    function isLaporanPelapor(tok) {
      return isFieldWorker(tok) || tok in ['WAKIF', 'ADIB'];
    }

    // ===== laporan collection =====
    // Worker submissions dari lapor.html + Wakif input dari monitor-v2.
    match /laporan/{laporanId} {

      // READ: terbuka untuk semua (dashboard butuh listener, Living Lab future fetch)
      // Privacy enforcement bisa di-tighten di Phase 2 dengan Auth.
      allow read: if true;

      // CREATE: validasi minimal — mencegah spam + struktur baseline.
      allow create: if
        // Worker valid (atau Wakif via monitor-v2 dengan pelapor='WAKIF') — single-source isLaporanPelapor()
        isLaporanPelapor(request.resource.data.pelapor)
        // Wajib ada tanggal entry
        && request.resource.data.tanggal is string
        // Wajib ada kategori aktivitas
        && request.resource.data.kategori is string
        // Wajib ada created_at (client-side ISO string)
        && request.resource.data.created_at is string
        // Schema version control
        && request.resource.data.schema_version is string
        // Size limit — max ~1 MB per entry (Firestore hard limit) — soft limit untuk warning di app
        && request.resource.size() < 900000;

      // UPDATE: open di Phase 1 (locked 23 Mei 2026 untuk support Wakif Form Edit cross-browser sync).
      // Casus: Wakif edit entry di monitor-v2 → harus push Firestore supaya sync ke device lain.
      // Validation: pelapor tetap di allowed list + tanggal masih string.
      // Phase 2 (post-Firebase-Auth): tighten ke Wakif role-only via custom claims.
      allow update: if
        isLaporanPelapor(request.resource.data.pelapor)
        && request.resource.data.tanggal is string
        && request.resource.size() < 900000;

      // DELETE: open di Phase 1 (locked 23 Mei 2026 untuk support Wakif Form Delete + cross-browser propagation).
      // Casus: Wakif delete entry di monitor-v2 → harus deleteDoc dari Firestore supaya tidak re-emerge via listener.
      // Phase 2: tighten ke Wakif role-only.
      allow delete: if true;
    }

    // ===== workers collection (last_active tracking) =====
    match /workers/{workerId} {
      // READ open (Wakif dashboard display)
      allow read: if true;

      // CREATE/UPDATE: hanya kalau workerId match pelapor valid
      allow create, update: if
        isFieldWorker(workerId)
        && request.resource.data.last_active is string;

      // DELETE: locked
      allow delete: if false;
    }

    // ===== audit_log collection (append-only) =====
    match /audit_log/{logId} {
      // READ: locked di Phase 1 (Wakif harus check via Firebase Console)
      // Phase 2: open untuk Wakif role
      allow read: if false;

      // CREATE: open untuk audit trail dari lapor.html / monitor-v2
      allow create: if
        request.resource.data.action is string
        && request.resource.data.timestamp is string
        && request.resource.size() < 100000;

      // UPDATE/DELETE: forever locked — audit log harus immutable
      allow update, delete: if false;
    }

    // ===== LAYER 1 SYSTEMATIC SYNC (24 Mei 2026) — 7 collections singleton =====
    // Apply Pattern #10 ke semua Wakif state. Public READ + open WRITE Phase 1,
    // DELETE locked (preserve audit history). Phase 2 (post-Auth): tighten role-based.
    // Collections: upah, cashbook, opt_observations, panen_data, panen_lots,
    //              panen_sampling, sop_status.

    match /upah/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.version is string
        && request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /cashbook/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.version is string
        && request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /opt_observations/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.version is string
        && request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /panen_data/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.version is string
        && request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /panen_lots/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.version is string
        && request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /panen_sampling/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.version is string
        && request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /sop_status/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.version is string
        && request.resource.size() < 1000000;
      allow delete: if false;
    }

    // ===== Collections shipped Mei-Juni 2026 (missing from previous rules update) =====
    // Distribusi PIC singleton (Pattern #10), SOP Master, Worker Defs Custom cross-device sync
    match /distribusi_pic/{docId} {
      allow read: if true;
      allow create, update: if request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /sop_master/{docId} {
      allow read: if true;
      allow create, update: if request.resource.size() < 1000000;
      allow delete: if false;
    }

    match /worker_defs_custom/{docId} {
      allow read: if true;
      allow create, update: if request.resource.size() < 1000000;
      allow delete: if false;
    }

    // ===== SOP Compliance bridge (6 Jul 2026) — NOTE penting =====
    // Angka compliance live (Apr–Kini) dari dashboard TIDAK pakai collection `compliance/*` sendiri
    // (butuh publish rule baru di Console — dihindari). Sebagai gantinya di-REUSE doc
    // `sop_status/compliance` (rule sop_status di atas SUDAH mengizinkan write asalkan ada
    // field `version:string`). Dashboard syncComplianceToFirestore() → setDoc(sop_status/compliance,
    // {version:'compliance-1.0', year, ytd_pct, ...}); Living Lab kartu Live fetch dari doc yang sama.
    // Jadi TIDAK perlu blok rule `compliance/*` terpisah.

    // ===== milestones collection (singleton pattern, locked 23 Mei 2026) =====
    // Curated milestones by Wakif via Tab Milestones Publik di monitor-v2.html.
    // Pattern #10 Firestore Sync Global Variable (sync `MILESTONES` array <-> Firestore).
    //
    // Migration trigger: localStorage MILESTONES per-browser tidak cross-sync —
    // Wakif publish di Safari hilang dari Chrome dashboard. Fix: cloud source of truth.
    //
    // Living Lab strategy B (locked 23 Mei): fetch langsung dari Firestore (real-time),
    // fallback ke data/aktivitas-publik.json kalau Firestore offline.
    match /milestones/{milestoneDocId} {

      // READ open: Living Lab public fetch + Wakif dashboard onSnapshot listener
      allow read: if true;

      // CREATE/UPDATE: open di Phase 1 (konsisten dengan pattern distribusi_pic + sop_master)
      // Phase 2 (post-Firebase-Auth): tighten ke Wakif role-only via custom claims.
      allow create, update: if
        request.resource.data.version is string
        && request.resource.data.data is list
        && request.resource.data.updated_at != null
        && request.resource.size() < 1000000;  // 1MB soft limit per Firestore doc

      // DELETE: locked — hanya via Firebase Console (preserve audit history)
      allow delete: if false;
    }

    // ===== Default deny =====
    // Collection lain yang belum di-define → deny semuanya
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
