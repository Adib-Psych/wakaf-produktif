{
  "schema_version": "1.1",
  "locked_at": "2026-05-16",
  "title": "Role-Based Field Visibility — Schema Design v1.0",
  "principle": "1 schema, 2 view, 4 visibility tier. Worker PWA cuma lihat field hijau/biru/kuning. Field ungu silent skip — Adib fill di dashboard.",
  "tiers": {
    "worker": {
      "label": "Worker",
      "color": "#2D8466",
      "desc": "Worker input source. Adib read-only / bisa edit."
    },
    "wakif_only": {
      "label": "Wakif-Only",
      "color": "#8B5CF6",
      "desc": "Hidden silent dari worker form. Adib full input."
    },
    "both": {
      "label": "Both",
      "color": "#3B82F6",
      "desc": "Worker default, Adib bisa override."
    },
    "auto": {
      "label": "Auto",
      "color": "#F59E0B",
      "desc": "System-filled (GPS/Open-Meteo/token/counter)."
    }
  },
  "master_fields": [
    {
      "id": "f-pelapor",
      "label": "Pelapor",
      "type": "radio_chip (3 opsi)",
      "visibility": "auto",
      "justification": "Worker PWA pre-set dari URL token (e.g., ?w=YIT). Worker tidak pilih manual. Adib lihat read-only di dashboard."
    },
    {
      "id": "f-tgl",
      "label": "Tanggal Aktivitas",
      "type": "date",
      "visibility": "both",
      "justification": "Worker default today, boleh adjust ±1-2 hari (late entry). Adib bisa override saat reklasifikasi."
    },
    {
      "id": "form-bidang",
      "label": "Kebun",
      "type": "radio_chip (4 opsi)",
      "visibility": "both",
      "justification": "Worker pilih lokasi kerja. Adib visible — bisa override jika worker salah klasifikasi."
    },
    {
      "id": "f-blok",
      "label": "Blok / Lokasi spesifik",
      "type": "text",
      "visibility": "both",
      "justification": "Optional, worker boleh isi sub-area (e.g., \"B1-A baris 3\")."
    },
    {
      "id": "form-cuaca-pagi",
      "label": "Cuaca Pagi",
      "type": "radio_chip",
      "visibility": "auto",
      "justification": "GPS+Open-Meteo pull saat form open. Worker override allowed jika beda dengan observasi langsung."
    },
    {
      "id": "form-cuaca-siang",
      "label": "Cuaca Siang",
      "type": "radio_chip",
      "visibility": "auto",
      "justification": "Sama — Open-Meteo siang."
    },
    {
      "id": "f-rainfall-24h",
      "label": "Curah hujan 24h (mm)",
      "type": "number",
      "visibility": "auto",
      "justification": "Open-Meteo precipitation last 24h. Worker override allowed (BMKG / observasi)."
    },
    {
      "id": "f-rainfall-7d",
      "label": "Curah hujan 7d (mm)",
      "type": "number",
      "visibility": "auto",
      "justification": "Open-Meteo precipitation last 7d. Worker override allowed."
    },
    {
      "id": "form-rainfall-source",
      "label": "Sumber data hujan",
      "type": "radio_chip",
      "visibility": "worker",
      "justification": "Worker pilih: observasi / BMKG / estimasi / Open-Meteo. Affirms data provenance."
    },
    {
      "id": "f-kategori",
      "label": "Kategori Aktivitas",
      "type": "select (21 opsi)",
      "visibility": "both",
      "justification": "Worker pilih dari filtered list (SOP-aware untuk worker per role). Adib full access ke 21 kategori."
    },
    {
      "id": "f-durasi",
      "label": "Durasi Kerja",
      "type": "radio_chip",
      "visibility": "worker",
      "justification": "WAJIB worker — auto-link ke UPAH_ITEMS (sweat equity vs harian vs panjat/pohon). Adib read-only."
    },
    {
      "id": "f-pekerja",
      "label": "Jumlah Pekerja",
      "type": "number",
      "visibility": "worker",
      "justification": "Worker input (1 default, support gotong royong)."
    },
    {
      "id": "f-pohon",
      "label": "Jumlah Pohon Dikerjakan",
      "type": "number",
      "visibility": "worker",
      "justification": "Output measurable, worker source."
    },
    {
      "id": "f-catatan",
      "label": "Catatan Kualitatif",
      "type": "textarea (+ mic)",
      "visibility": "worker",
      "justification": "Free-text + voice transcribe (Phase 1A: Indonesian native browser). Worker source. Channel observasi un-structured."
    },
    {
      "id": "f-foto-files",
      "label": "Foto Bukti",
      "type": "file (multi)",
      "visibility": "worker",
      "justification": "Worker upload inline. Adib view di gallery."
    },
    {
      "id": "created_at",
      "label": "Timestamp ISO",
      "type": "datetime",
      "visibility": "auto",
      "justification": "System on submit."
    },
    {
      "id": "id",
      "label": "Entry UID",
      "type": "string",
      "visibility": "auto",
      "justification": "lap_YYYYMMDD_xxxxx"
    },
    {
      "id": "compliance",
      "label": "Compliance Status",
      "type": "enum",
      "visibility": "auto",
      "justification": "Derived dari alerts engine."
    },
    {
      "id": "alerts",
      "label": "Climate Alerts",
      "type": "array",
      "visibility": "auto",
      "justification": "Derived dari computeRainfallAlerts()."
    },
    {
      "id": "gps_coords",
      "label": "Lat/Lng GPS",
      "type": "string",
      "visibility": "auto",
      "justification": "NEW Phase 1A — Worker PWA capture GPS saat submit untuk audit lokasi kerja."
    },
    {
      "id": "device_id",
      "label": "Browser Fingerprint",
      "type": "string",
      "visibility": "auto",
      "justification": "NEW Phase 1A — worker device traceability untuk multi-worker conflict."
    }
  ],
